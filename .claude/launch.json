{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "BNBScan Web (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@bnbscan/explorer", "dev"],
      "port": 3000,
      "autoPort": false,
      "env": {
        "CHAIN": "bnb",
        "NEXT_PUBLIC_CHAIN": "bnb"
      }
    },
    {
      "name": "BNBScan Indexer (Worker)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@bnbscan/indexer", "dev"],
      "port": 0
    },
    {
      "name": "Explorer BNB (Next.js)",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["pnpm", "--filter", "@bnbscan/explorer", "exec", "next", "dev", "-p", "3002"],
      "port": 3002,
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin",
        "CHAIN": "bnb",
        "NEXT_PUBLIC_CHAIN": "bnb"
      }
    },
    {
      "name": "Explorer ETH (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "@bnbscan/explorer", "exec", "next", "dev", "-p", "3003"],
      "port": 3003,
      "env": {
        "CHAIN": "eth",
        "NEXT_PUBLIC_CHAIN": "eth"
      }
    },
    {
      "name": "All (Turbo)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["dev"],
      "port": 3000
    },
    {
      "name": "Status Page",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tsx", "apps/status/src/server.ts"],
      "port": 3090,
      "env": {
        "ADMIN_SECRET": "${ADMIN_SECRET}"
      }
    }
  ]
}
