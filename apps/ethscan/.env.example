# ── Ethereum RPC (Chainstack Growth — ETH endpoint) ───────────────────────────
ETH_RPC_URL=https://ethereum-mainnet.core.chainstack.com/YOUR_KEY

# ── Database (Railway Postgres — ethscan-db) ──────────────────────────────────
# NOTE: must be ETH_DATABASE_URL, not DATABASE_URL (avoids collision with bnbscan-db)
ETH_DATABASE_URL=postgresql://user:password@host:5432/ethscan

# ── External enrichment APIs ──────────────────────────────────────────────────
# Moralis — https://moralis.io (free tier: 40K CU/day)
MORALIS_API_KEY=

# ── Network switcher (peer explorer URL) ──────────────────────────────────────
# Production: set to https://bnbscan.com
NEXT_PUBLIC_PEER_URL=https://bnbscan.com

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
