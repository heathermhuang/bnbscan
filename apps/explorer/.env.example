# ── BNB Chain RPC (Chainstack Growth — BSC endpoint) ─────────────────────────
BNB_RPC_URL=https://bsc-mainnet.core.chainstack.com/YOUR_KEY

# ── Database (Railway Postgres — bnbscan-db) ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/bnbscan

# ── Redis (Railway Redis — bnbscan-redis) ─────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── External enrichment APIs ──────────────────────────────────────────────────
# Moralis — https://moralis.io (free tier: 40K CU/day)
MORALIS_API_KEY=

# ── Network switcher (peer explorer URL) ──────────────────────────────────────
# Production: set to https://ethscan.io
NEXT_PUBLIC_PEER_URL=https://ethscan.io

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=production
