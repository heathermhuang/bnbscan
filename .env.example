# BNB Chain RPC
# Production: use Ankr free tier (30M req/mo) — sign up at https://ankr.com
#   BNB_RPC_URL=https://rpc.ankr.com/bsc/<YOUR_API_KEY>
# Dev fallback (rate-limited Binance public node):
BNB_RPC_URL=https://bsc-dataseed1.binance.org/

# Database (Render managed Postgres)
DATABASE_URL=postgresql://user:pass@host:5432/bnbscan

# Redis (Render managed Redis or Upstash free tier)
REDIS_URL=redis://localhost:6379

# Contract verification
SOURCIFY_API=https://sourcify.dev/server

# API rate limiting
API_SECRET=changeme

# Optional: set to production in deployment
NODE_ENV=development
